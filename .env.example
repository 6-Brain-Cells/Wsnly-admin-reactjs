# Backend API base URL (Django + DRF)
# Production: https://wslny-api.icyforest-4fb366f4.uaenorth.azurecontainerapps.io
# Local dev:   http://localhost:8000  (run `docker compose up` in Wsnly-Backend/)
VITE_API_BASE_URL=https://wslny-api.icyforest-4fb366f4.uaenorth.azurecontainerapps.io

# Optional: Google OAuth client ID. Leave empty to hide the Google sign-in button.
VITE_GOOGLE_CLIENT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Local dev credentials (when VITE_API_BASE_URL=http://localhost:8000)
# ─────────────────────────────────────────────────────────────────────────────
# When the backend is started via `docker compose up` and ADMIN_SEED_PASSWORD
# is unset, the seed_admin command creates a default admin using the hardcoded
# DEV fallback password (Admin@Wslny2026). This is dev-only and requires
# DEBUG=True on the backend; production deployments must always set
# ADMIN_SEED_PASSWORD explicitly.
#
# Local dev login:
#   Email:    admin@wslny.com
#   Password: Admin@Wslny2026
#
# To override (recommended for shared environments):
#   Wsnly-Backend/docker-compose.yml → add `ADMIN_SEED_PASSWORD: <your password>`
#   Wsnly-Backend/.env              → ADMIN_SEED_PASSWORD=<your password>
